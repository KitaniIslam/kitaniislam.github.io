---
const { title = 'Kitani Portfolio', description = 'Senior Full Stack Developer Portfolio' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <script is:inline>
      const contactModal = document.querySelector('[data-contact-modal]');
      if (contactModal) {
        const openTriggers = document.querySelectorAll('[data-contact-open]');
        const closeTriggers = contactModal.querySelectorAll('[data-contact-close]');
        const openModal = () => {
          contactModal.hidden = false;
          document.body.style.overflow = 'hidden';
        };
        const closeModal = () => {
          contactModal.hidden = true;
          document.body.style.overflow = '';
        };
        openTriggers.forEach((trigger) => {
          trigger.addEventListener('click', openModal);
        });
        closeTriggers.forEach((trigger) => {
          trigger.addEventListener('click', closeModal);
        });
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeModal();
        });
      }
    </script>
  </body>
</html>
