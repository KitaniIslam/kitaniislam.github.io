---
interface Props {
  email: string;
  whatsappHref: string;
}

const { email, whatsappHref } = Astro.props;
---

<div class="contact-modal" data-contact-modal hidden>
  <div class="contact-modal-backdrop" data-contact-close></div>
  <article class="contact-modal-panel" role="dialog" aria-modal="true" aria-labelledby="contact-modal-title">
    <button class="contact-modal-close" type="button" aria-label="Close contact options" data-contact-close>✕</button>
    <p class="contact-modal-eyebrow">Let&apos;s Talk</p>
    <h2 id="contact-modal-title">Choose how you want to reach me</h2>
    <p class="contact-modal-description">Pick the channel that fits you best.</p>
    <div class="contact-modal-actions">
      <a class="contact-option-card" href={`mailto:${email}`}>
        <span class="contact-option-icon contact-option-icon-email" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.8" />
            <path d="M5.5 7.5 12 12.5l6.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="contact-option-label">Email</span>
        <strong>Write an email</strong>
        <p>{email}</p>
      </a>
      <a class="contact-option-card contact-option-whatsapp" href={whatsappHref} target="_blank" rel="noreferrer">
        <span class="contact-option-icon contact-option-icon-whatsapp" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.05 4.94A9.9 9.9 0 0 0 12.03 2C6.55 2 2.1 6.45 2.1 11.92c0 1.75.46 3.46 1.33 4.97L2 22l5.27-1.38a9.9 9.9 0 0 0 4.75 1.21h.01c5.47 0 9.92-4.45 9.92-9.92 0-2.65-1.03-5.13-2.9-6.97Zm-7.02 15.2h-.01a8.26 8.26 0 0 1-4.21-1.15l-.3-.18-3.13.82.84-3.05-.2-.31a8.23 8.23 0 0 1-1.27-4.38c0-4.55 3.71-8.26 8.27-8.26 2.21 0 4.28.86 5.84 2.42a8.2 8.2 0 0 1 2.42 5.84c0 4.56-3.7 8.25-8.25 8.25Zm4.53-6.18c-.25-.13-1.47-.72-1.7-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.98-.14.16-.29.18-.54.06-.25-.13-1.05-.39-2-1.23-.74-.66-1.24-1.47-1.38-1.72-.15-.25-.01-.38.11-.5.11-.11.25-.29.37-.44.12-.14.17-.25.25-.41.08-.17.04-.31-.02-.44-.06-.13-.56-1.35-.77-1.85-.2-.48-.41-.41-.56-.42h-.48c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1 0 1.24.9 2.44 1.03 2.6.12.17 1.77 2.7 4.29 3.78.6.26 1.07.41 1.43.53.6.19 1.15.16 1.58.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.05-.1-.21-.16-.46-.29Z" />
          </svg>
        </span>
        <span class="contact-option-label">WhatsApp</span>
        <strong>Chat on WhatsApp</strong>
        <p>Open a direct conversation</p>
      </a>
    </div>
  </article>
</div>
