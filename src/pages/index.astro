---
import MainLayout from '../layouts/MainLayout.astro';
import portfolio from '../data/portfolio.json';

const navItems = [
  { label: 'Home', href: '#home' },
  { label: 'Services', href: '#services' },
  { label: 'Work', href: '#case-study' },
  { label: 'Stack', href: '#tech' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#footer' }
];

const techGroups =
  Array.isArray(portfolio.technologyGroups) && portfolio.technologyGroups.length > 0
    ? portfolio.technologyGroups
    : [{ title: 'Technologies', items: portfolio.technologies }];
const allTech = techGroups.flatMap((group) => group.items ?? []);
const midpoint = Math.ceil(allTech.length / 2);
const firstTechRow = allTech.slice(0, midpoint);
const secondTechRow = allTech.slice(midpoint);
const hasMoreTimeline = portfolio.experience.items.length > 3;
const toBasePath = (value: string) => {
  if (typeof value !== 'string' || !value.startsWith('/')) return value;
  const base = import.meta.env.BASE_URL;
  const normalizedBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return `${normalizedBase}${value}`;
};
---

<MainLayout title={`${portfolio.meta.name} | Portfolio`} description={portfolio.meta.shortBio}>
  <div class="page-shell" id="home">
    <header class="topbar" data-nav>
       <div class="hero-badge"><span>🚀</span></div>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-label="Toggle navigation" data-menu-toggle>
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="topnav" data-menu>
        {navItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <a href={portfolio.meta.primaryCtaHref} class="button nav-cta">{portfolio.meta.primaryCtaLabel}</a>
    </header>

    <main>
      <section class="hero section-spacing">
        <div class="hero-content">
          <div class="hero-text">
            <div class="hero-badge">
              <span>👋</span>
              <p>Available for work</p>
            </div>
            <h1 class="hero-title">
              Hi, I'm <span class="highlight">{portfolio.meta.name}</span>
            </h1>
            <p class="hero-subtitle">{portfolio.meta.role}</p>
            <p class="hero-description">{portfolio.meta.shortBio}</p>
            <div class="hero-actions">
              <a class="button primary" href={portfolio.meta.primaryCtaHref}>{portfolio.meta.primaryCtaLabel}</a>
              <a class="button secondary" href={toBasePath(portfolio.meta.secondaryCtaHref)} download>{portfolio.meta.secondaryCtaLabel}</a>
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-image-wrapper">
              <div class="hero-image-bg"></div>
              <img src={toBasePath('/images/me.jpg')} alt={portfolio.meta.name} class="hero-image" />
              <div class="hero-image-decoration"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="section-spacing section-block">
        <div class="section-head">
          <h2>{portfolio.services.title}</h2>
          <p>{portfolio.services.description}</p>
        </div>

        <div class="service-grid">
          {portfolio.services.items.map((service, index) => (
            <article class="service-feature">
              <p class="service-index">0{index + 1}</p>
              <div class="service-copy">
                <h3>{service.title}</h3>
                <p>{service.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="case-study" class="section-spacing section-block">
        <div class="section-head">
          <h2>{portfolio.caseStudies.title}</h2>
          <p>{portfolio.caseStudies.description}</p>
        </div>

        <div class={`carousel project-carousel ${portfolio.caseStudies.items.length === 1 ? 'single-card' : ''}`} data-carousel>
          {portfolio.caseStudies.items.length > 1 && (
            <button class="carousel-btn prev" aria-label="Previous project card" data-prev>←</button>
          )}
          <div class="carousel-viewport">
            <div class="carousel-track" data-track>
              {portfolio.caseStudies.items.map((study) => (
                <a class="project-card" data-case-card href={toBasePath(study.href)}>
                  <div class="project-card-media">
                    <img src={toBasePath(study.image)} alt={study.name} loading="lazy" />
                  </div>
                  <div class="project-card-body">
                    <p class="chip">{study.domain}</p>
                    <h3>{study.name}</h3>
                    <p>{study.impact}</p>
                    <span class="project-card-link">View project</span>
                  </div>
                </a>
              ))}
              <article class="project-card project-card-placeholder" data-case-card aria-label="More projects coming soon">
                <div class="project-card-media project-card-placeholder-media">
                  <div class="project-card-placeholder-mark" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                </div>
                <div class="project-card-body">
                  <p class="chip">More Work Coming Soon</p>
                  <h3>More projects coming soon</h3>
                  <p>Additional product work, redesigns, and delivery stories will be added here as more case studies are prepared.</p>
                  <span class="project-card-link project-card-link-muted">In progress</span>
                </div>
              </article>
            </div>
          </div>
          {portfolio.caseStudies.items.length > 1 && (
            <button class="carousel-btn next" aria-label="Next project card" data-next>→</button>
          )}
        </div>
      </section>

      <section id="tech" class="section-spacing section-block tech-section">
        <div class="section-head">
          <h2>{portfolio.technologiesSection.title}</h2>
          <p>{portfolio.technologiesSection.description}</p>
          <button class="tech-switch" type="button" aria-pressed="true" data-tech-toggle>
            Animation: ON
          </button>
        </div>

        <div class="logo-marquee" data-tech-animated>
          <div class="logo-track left">
            {[...firstTechRow, ...firstTechRow].map((tech) => (
              <article class="logo-item">
                <img src={toBasePath(tech.logo)} alt={tech.name} loading="lazy" />
                <span>{tech.name}</span>
              </article>
            ))}
          </div>
          <div class="logo-track right">
            {[...secondTechRow, ...secondTechRow].map((tech) => (
              <article class="logo-item">
                <img src={toBasePath(tech.logo)} alt={tech.name} loading="lazy" />
                <span>{tech.name}</span>
              </article>
            ))}
          </div>
        </div>

        <div class="tech-badge-wall is-hidden" data-tech-static>
          <div class="tech-groups">
            {techGroups.map((group) => (
              <div class="tech-group">
                <h4>{group.title}</h4>
                <div class="tech-row">
                  {(group.items ?? []).map((tech) => (
                    <article class="logo-item">
                      <img src={toBasePath(tech.logo)} alt={tech.name} loading="lazy" />
                      <span>{tech.name}</span>
                    </article>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="experience" class="section-spacing section-block experience-section">
        <div class="section-head">
          <h2>{portfolio.experience.title}</h2>
          <p>Latest three items are shown by default. Expand to view full timeline.</p>
        </div>

        <ol class="timeline" data-timeline>
          {portfolio.experience.items.map((item, index) => (
            <li class={index > 2 ? 'timeline-extra-item is-collapsed' : ''}>
              <p class="period">{item.period}</p>
              <h3>{item.role}</h3>
              <p>{item.details}</p>
            </li>
          ))}
        </ol>

        {hasMoreTimeline && (
          <button class="timeline-toggle" type="button" aria-expanded="false" data-timeline-toggle>
            Show full timeline
          </button>
        )}
      </section>

      <section id="education" class="section-spacing section-block education-section">
        <div class="section-head">
          <h2>{portfolio.education.title}</h2>
          <p>{portfolio.education.description}</p>
        </div>

        <div class="education-grid">
          {portfolio.education.items.map((edu) => (
            
              <div class="education-content">
                <h3>{edu.degree}</h3>
                <p class="education-institution">{edu.institution}</p>
                <p class="education-period">{edu.period}</p>
                <p class="education-location">{edu.location}</p>
                <p class="education-description">{edu.description}</p>
              </div>
            
          ))}
        </div>
      </section>

      <section id="awards" class="section-spacing section-block awards-section">
        <div class="section-head">
          <h2>{portfolio.awards.title}</h2>
          <p>{portfolio.awards.description}</p>
        </div>

        <div class="awards-grid">
          {portfolio.awards.items.map((award) => (
              <div class="award-content">
                <h3>{award.title}</h3>
                <p class="award-organization">{award.organization}</p>
                <p class="award-year">{award.year}</p>
                <p class="award-description">{award.description}</p>
              </div>
          ))}
        </div>
      </section>
    </main>

    <footer id="footer" class="footer section-spacing">
      <div class="footer-horizontal">
        <div class="footer-identity">
          <h2>{portfolio.meta.name}</h2>
          <p>{portfolio.footer.email}</p>
        </div>
        <a href={toBasePath(portfolio.meta.secondaryCtaHref)} class="button ghost" download>Download CV</a>
        <div class="footer-social-icons" aria-label="Social links">
          {portfolio.footer.socials
            .filter((social) => social.icon !== '@')
            .map((social) => (
              <a href={social.href} target="_blank" rel="noreferrer" aria-label={social.label} class="footer-icon-link">
                {social.icon === 'in' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#0077B5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="3" />
                    <path d="M8 10v6" />
                    <path d="M12 16v-3a2 2 0 0 1 4 0v3" />
                  </svg>
                )}
                {social.icon === 'wa' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 11.5A8.5 8.5 0 0 1 7.5 19l-3.5 1 1-3.3A8.5 8.5 0 1 1 20 11.5Z" />
                    <path d="M9.5 9.5c.3 2 1.7 3.8 4 4.7" />
                  </svg>
                )}
                {social.icon === 'ig' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#E4405F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle cx="17.5" cy="6.5" r="1" />
                  </svg>
                )}
              </a>
            ))}
        </div>
      </div>
    </footer>

  </div>

  <script is:inline>
    const navRoot = document.querySelector('[data-nav]');
    const menuToggle = navRoot?.querySelector('[data-menu-toggle]');
    const menu = navRoot?.querySelector('[data-menu]');
    const navLinks = menu?.querySelectorAll('a') ?? [];

    const setMenuState = (open) => {
      if (!navRoot || !menuToggle || !menu) return;
      navRoot.classList.toggle('menu-open', open);
      menuToggle.setAttribute('aria-expanded', String(open));
    };

    menuToggle?.addEventListener('click', () => {
      const isOpen = navRoot?.classList.contains('menu-open');
      setMenuState(!isOpen);
    });

    navLinks.forEach((link) => {
      link.addEventListener('click', () => setMenuState(false));
    });

    const techToggle = document.querySelector('[data-tech-toggle]');
    const techAnimated = document.querySelector('[data-tech-animated]');
    const techStatic = document.querySelector('[data-tech-static]');
    let techAnimationOn = true;

    const setTechMode = (on) => {
      techAnimationOn = on;
      if (techAnimated) techAnimated.classList.toggle('is-hidden', !on);
      if (techStatic) techStatic.classList.toggle('is-hidden', on);
      if (techToggle) {
        techToggle.setAttribute('aria-pressed', String(on));
        techToggle.textContent = `Animation: ${on ? 'ON' : 'OFF'}`;
      }
    };

    setTechMode(true);
    techToggle?.addEventListener('click', () => setTechMode(!techAnimationOn));

    const timeline = document.querySelector('[data-timeline]');
    const timelineToggle = document.querySelector('[data-timeline-toggle]');
    let timelineExpanded = false;

    const setTimelineMode = (expanded) => {
      timelineExpanded = expanded;
      if (!timeline || !timelineToggle) return;
      timeline.classList.toggle('is-expanded', expanded);
      timelineToggle.setAttribute('aria-expanded', String(expanded));
      timelineToggle.textContent = expanded ? 'Show less' : 'Show full timeline';
    };

    setTimelineMode(false);
    timelineToggle?.addEventListener('click', () => setTimelineMode(!timelineExpanded));

    const carousels = document.querySelectorAll('[data-carousel]');
    carousels.forEach((carousel) => {
      const track = carousel.querySelector('[data-track]');
      const viewport = carousel.querySelector('.carousel-viewport');
      const cards = track ? Array.from(track.querySelectorAll('[data-case-card]')) : [];
      const prev = carousel.querySelector('[data-prev]');
      const next = carousel.querySelector('[data-next]');
      const total = cards.length;
      let index = 0;
      let wheelLock = false;
      let touchStartX = 0;

      const cardsPerView = () => (window.matchMedia('(min-width: 1100px)').matches ? 2 : 1);
      const maxIndex = () => Math.max(0, total - cardsPerView());

      const update = () => {
        if (!track || cards.length === 0) return;
        const gap = parseFloat(getComputedStyle(track).gap || '0');
        const cardWidth = cards[0].getBoundingClientRect().width + gap;
        track.style.transform = `translateX(-${index * cardWidth}px)`;
      };

      prev?.addEventListener('click', () => {
        const step = cardsPerView();
        index = index <= 0 ? maxIndex() : Math.max(0, index - step);
        update();
      });

      next?.addEventListener('click', () => {
        const step = cardsPerView();
        index = index >= maxIndex() ? 0 : Math.min(maxIndex(), index + step);
        update();
      });

      viewport?.addEventListener(
        'wheel',
        (event) => {
          if (Math.abs(event.deltaY) < 10 || wheelLock) return;
          event.preventDefault();
          wheelLock = true;
          const step = cardsPerView();
          if (event.deltaY > 0) {
            index = index >= maxIndex() ? 0 : Math.min(maxIndex(), index + step);
          } else {
            index = index <= 0 ? maxIndex() : Math.max(0, index - step);
          }
          update();
          setTimeout(() => {
            wheelLock = false;
          }, 380);
        },
        { passive: false }
      );

      viewport?.addEventListener('touchstart', (event) => {
        touchStartX = event.changedTouches[0].clientX;
      });

      viewport?.addEventListener('touchend', (event) => {
        const delta = event.changedTouches[0].clientX - touchStartX;
        if (Math.abs(delta) < 35) return;
        const step = cardsPerView();
        if (delta < 0) {
          index = index >= maxIndex() ? 0 : Math.min(maxIndex(), index + step);
        } else {
          index = index <= 0 ? maxIndex() : Math.max(0, index - step);
        }
        update();
      });

      window.addEventListener('resize', () => {
        index = Math.min(index, maxIndex());
        update();
      });

      update();
    });
  </script>
</MainLayout>
